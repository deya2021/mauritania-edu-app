  "lesson_contents": [
    {
      "id": "content_math_lesson1",
      "lessonId": "math_lesson1",
      "sections": [
        {
          "title": "Introduction aux nombres",
          "content": "# Les nombres de 1 à 10\n\nLes nombres sont partout autour de nous. Apprenons les premiers nombres de 1 à 10.\n\n## Les nombres\n\n- 1 : Un\n- 2 : Deux\n- 3 : Trois\n- 4 : Quatre\n- 5 : Cinq\n- 6 : Six\n- 7 : Sept\n- 8 : Huit\n- 9 : Neuf\n- 10 : Dix",
          "lockedInitially": false,
          "order": 1
        },
        {
          "title": "Exercices pratiques",
          "content": "## Compter les objets\n\nMaintenant, pratiquons le comptage avec des objets.\n\nRegardez autour de vous et comptez:\n- Combien de doigts avez-vous?\n- Combien de chaises dans la classe?\n- Combien de livres sur la table?",
          "lockedInitially": false,
          "order": 2
        }
      ],
      "exercises": [
        {
          "id": "ex1",
          "type": "mcq",
          "question": "Combien font 3 + 2?",
          "options": ["4", "5", "6", "7"],
          "correctAnswer": "1",
          "explanation": "3 + 2 = 5. Nous ajoutons trois à deux pour obtenir cinq."
        },
        {
          "id": "ex2",
          "type": "true_false",
          "question": "Le nombre 7 vient après le nombre 6.",
          "correctAnswer": "true",
          "explanation": "C'est vrai! Dans l'ordre des nombres, 7 vient directement après 6."
        },
        {
          "id": "ex3",
          "type": "mcq",
          "question": "Quel est le nombre qui vient avant 10?",
          "options": ["8", "9", "11", "7"],
          "correctAnswer": "1",
          "explanation": "Le nombre 9 vient juste avant 10."
        }
      ]
    },
    {
      "id": "content_arabic_lesson1",
      "lessonId": "arabic_lesson1",
      "sections": [
        {
          "title": "الحروف الأولى",
          "content": "# الحروف العربية الأولى\n\nسنتعلم اليوم ثلاثة حروف من الأبجدية العربية.\n\n## الحرف الأول: أ (ألف)\n\nألف هو الحرف الأول في الأبجدية العربية.\n\nأمثلة: أسد، أرنب، أب\n\n## الحرف الثاني: ب (باء)\n\nباء هو الحرف الثاني.\n\nأمثلة: بيت، بطة، باب\n\n## الحرف الثالث: ت (تاء)\n\nتاء هو الحرف الثالث.\n\nأمثلة: تفاحة، تمر، تلميذ",
          "lockedInitially": false,
          "order": 1
        }
      ],
      "exercises": [
        {
          "id": "ex1",
          "type": "mcq",
          "question": "ما هو الحرف الأول في كلمة 'أسد'؟",
          "options": ["ب", "أ", "ت", "س"],
          "correctAnswer": "1",
          "explanation": "الحرف الأول في كلمة أسد هو 'أ' (ألف)."
        },
        {
          "id": "ex2",
          "type": "true_false",
          "question": "حرف الباء يأتي بعد حرف الألف.",
          "correctAnswer": "true",
          "explanation": "صحيح! الباء هو الحرف الثاني بعد الألف."
        }
      ]
    }
  ],
